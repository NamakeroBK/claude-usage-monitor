<Window x:Class="ClaudeUsageMonitor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定 - Claude 使用量モニター" 
        Height="420" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF2D2D30">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Session Key -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="セッションキー" Foreground="White" Margin="0,0,0,4"/>
            <TextBox x:Name="SessionKeyTextBox" 
                     Height="24"
                     Background="#FF3F3F46"
                     Foreground="White"
                     BorderBrush="#FF5A5A5A"/>
            <Button Content="🔑 ログインして取得" 
                    Click="LoginToGetSessionKey_Click"
                    Padding="12,6"
                    Background="#FF0078D4"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Left"/>
            <TextBlock x:Name="ValidationStatus" 
                       Foreground="#FF808080" 
                       FontSize="10" 
                       Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Organization -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="組織" Foreground="White" Margin="0,0,0,4"/>
            <ComboBox x:Name="OrganizationComboBox"
                      Height="28"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Uuid"/>
            <TextBlock Text="※ ログインボタンで自動取得されます" 
                       Foreground="#FF808080" 
                       FontSize="10" 
                       Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Refresh Interval -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="自動更新間隔" Foreground="White" Margin="0,0,0,4"/>
            <ComboBox x:Name="IntervalComboBox"
                      Height="28"
                      SelectedIndex="1"
                      SelectionChanged="IntervalComboBox_SelectionChanged">
                <ComboBoxItem Content="1分" Tag="1"/>
                <ComboBoxItem Content="2分" Tag="2"/>
                <ComboBoxItem Content="5分" Tag="5"/>
                <ComboBoxItem Content="10分" Tag="10"/>
            </ComboBox>
        </StackPanel>
        
        <!-- Options -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <CheckBox x:Name="StartWithWindowsCheckBox" 
                      Content="Windows起動時に自動起動"
                      Foreground="White"/>
            <CheckBox x:Name="NotificationsCheckBox" 
                      Content="80%/90%で通知を表示"
                      Foreground="White"
                      Margin="0,4,0,0"
                      IsChecked="True"/>
            <CheckBox x:Name="ResetNotificationCheckBox" 
                      Content="リセット時に通知"
                      Foreground="White"
                      Margin="0,4,0,0"
                      IsChecked="True"/>
        </StackPanel>
        
        <!-- How to use -->
        <Border Grid.Row="4" Background="#FF252526" CornerRadius="4" Padding="8" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="使い方:" Foreground="#FFB0B0B0" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap" Foreground="#FF808080" FontSize="11" Margin="0,4,0,0">
1. 「ログインして取得」をクリック
2. claude.aiにログイン（Google等）
3. 自動的に使用量を取得します

※ Cloudflare保護のため、更新時は
   ブラウザ経由で取得します
                </TextBlock>
            </StackPanel>
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存" 
                    Click="Save_Click"
                    Padding="16,6"
                    Background="#FF0078D4"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"/>
            <Button Content="キャンセル" 
                    Click="Cancel_Click"
                    Padding="16,6"
                    Background="#FF3F3F46"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
