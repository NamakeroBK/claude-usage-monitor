<UserControl x:Class="ClaudeUsageMonitor.Views.MainPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ClaudeUsageMonitor.ViewModels"
             Width="280" Background="#FF2D2D30">
    
    <Border BorderBrush="#FF3F3F46" BorderThickness="1" CornerRadius="4">
        <StackPanel Margin="12">
            <!-- Header -->
            <TextBlock Text="Claude 使用量モニター" 
                       Style="{StaticResource HeaderText}"
                       Foreground="White" 
                       Margin="0,0,0,12"/>
            
            <!-- Session Usage (5-hour) -->
            <Border Background="#FF3F3F46" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⏱ セッション制限" Foreground="#FFB0B0B0" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding TimeUntilResetText}" Foreground="#FF808080" FontSize="10"/>
                    </Grid>
                    
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#FF1E1E1E" CornerRadius="3" Height="16" Margin="0,0,8,0">
                            <Border Background="{Binding CurrentLevel, Converter={StaticResource LevelToBrushConverter}}"
                                    CornerRadius="3" HorizontalAlignment="Left"
                                    Width="{Binding Utilization, Converter={StaticResource PercentToWidthConverter}}"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding UtilizationText}" Foreground="White" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Weekly Usage (7-day) -->
            <Border Background="#FF3F3F46" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📅 週間制限 (全モデル)" Foreground="#FFB0B0B0" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="{Binding WeeklyResetText}" Foreground="#FF808080" FontSize="10"/>
                    </Grid>
                    
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#FF1E1E1E" CornerRadius="3" Height="16" Margin="0,0,8,0">
                            <Border Background="#FF28A0F5" CornerRadius="3" HorizontalAlignment="Left"
                                    Width="{Binding WeeklyUtilization, Converter={StaticResource PercentToWidthConverter}}"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding WeeklyUtilizationText}" Foreground="White" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Sonnet Usage -->
            <Border Background="#FF3F3F46" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="💬 Sonnet制限" Foreground="#FFB0B0B0" FontSize="11"/>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#FF1E1E1E" CornerRadius="3" Height="16" Margin="0,0,8,0">
                            <Border Background="#FF6B6B6B" CornerRadius="3" HorizontalAlignment="Left"
                                    Width="{Binding SonnetUtilization, Converter={StaticResource PercentToWidthConverter}}"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding SonnetUtilizationText}" Foreground="White" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Status Bar -->
            <Border Background="#FF252526" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="プラン" Foreground="#FF808080" FontSize="10"/>
                        <TextBlock Text="{Binding PlanText}" Foreground="White"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="最終更新" Foreground="#FF808080" FontSize="10"/>
                        <TextBlock Text="{Binding LastUpdateText}" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Status -->
            <TextBlock Text="{Binding StatusText}" 
                       Foreground="#FF808080" 
                       FontSize="10"
                       Margin="0,0,0,8"/>
            
            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="⚙ 設定" 
                        Command="{Binding OpenSettingsCommand}"
                        Margin="0,0,4,0"
                        Padding="8,4"
                        Background="#FF3F3F46"
                        Foreground="White"
                        BorderThickness="0"/>
                
                <Button Content="🔄 更新" 
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,4,0"
                        Padding="8,4"
                        Background="#FF3F3F46"
                        Foreground="White"
                        BorderThickness="0"/>
                
                <Button Content="✕ 終了" 
                        Command="{Binding QuitCommand}"
                        Padding="8,4"
                        Background="#FF3F3F46"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
